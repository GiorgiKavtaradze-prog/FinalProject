## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Output of MSI Build packages
*.msi
*.msix
*.msm
*.msp

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode is a .NET coding add-in
.JustCode

# TeamCity is a build automation tool
_TeamCity*

# DotCover is a Code Coverage Tool
*.dotCover

# AxoCover is a Code Coverage Tool
.axoCover
/*_AxoCover/

# Coverlet is a free, cross-platform Code Coverage Tool
coverage*.json
coverage*.xml
coverage*.info

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator add-in
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2
DocProject/Help/html

# ClickOnce directory
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
# Note: Comment the next line if you want to checkin your web deploy settings,
# but be aware that they can contain sensitive information.
*.pubxml
*.publishproj

# Microsoft Azure Web App publish settings. Comment the next line if you want to
# checkin your web deploy settings, but be aware that they can contain
# sensitive information.
*.PublishSettings

# Sensitve files
*.pfx
*.publishsettings

# Others
sql/
*.Cache
ClientBin/
[Gg]enerated_files/
[Ss]cript[Dd]oc/
Generated_Code/
_vti_pvt/
_vti_cnf/
_vti_log/
_vti_txt/
_vti_bin/
_vti_rtxt/
_vti_shm/
_vti_script/
_vti_derived/
App_Data/*.mdf
App_Data/*.ldf
App_Data/*.sdf
App_Data/RadControlUploadTemp/
_UpgradeReport_Files/
Backup*/
StyleCop.Cache
StyleCop.SourceCache
[Ii]ntermediate/
_Chutzpah*
[Cc]heckout/
[Pp]ackages/
[Dd]ot[Nn]et[Cc]onf/
[Dd]ot[Nn]et[Cc]onf[Mm][Ss][Ii]/
[Dd]ot[Nn]et[Cc]onf[Mm][Ss][Ii][Xx]/
[Dd]ot[Nn]et[Cc]onf[Pp][Aa][Cc][Kk][Aa][Gg][Ee]/
[Dd]ot[Nn]et[Cc]onf[Pp][Aa][Cc][Kk][Aa][Gg][Ee][Ss]/
[Dd]ot[Nn]et[Cc]onf[Rr][Ee][Ll][Ee][Aa][Ss][Ee]/
[Dd]ot[Nn]et[Cc]onf[Rr][Ee][Ll][Ee][Aa][Ss][Ee][Ss]/
