# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.Development.json

# Visual Studio version-specific files
.vs/
*.swp
*.swo
*.tmp
*.temp

# NuGet Packages
*.nupkg
# The directory setup by NuGet
**/packages/*
# Except for the build/ directory
!**/packages/build/
# Or any other specific file you want to include
# !**/packages/my-package/config.xml

# Cake build
/tools/*
!/tools/packages.config

# Omnibus
**/Generated_Code/